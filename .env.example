# Copy to .env and fill in values. .env is gitignored; this template is not.
# Sourced by .zshrc on shell startup.

# Todoist — https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your_todoist_token_here

# AssemblyAI — https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# Default Google Workspace account for `gog` CLI
GOG_ACCOUNT=you@example.com

# --- Optional (uncomment if you use the matching skill/script) ---

# GitHub PAT for gh-issues skill — https://github.com/settings/tokens
# GH_TOKEN=ghp_your_token_here

# Gemini CLI skill — https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_key_here

# Best Buy API — https://developer.bestbuy.com/
# BBY_API_KEY=your_bestbuy_key_here

# Monarch Money skill
# MONARCH_EMAIL=you@example.com
# MONARCH_PASSWORD=your_password_here
# MONARCH_MFA_SECRET=your_totp_secret_here

# Logseq plugin skill — token from Logseq API server settings
# LOGSEQ_API_TOKEN=your_logseq_token_here

# TikTok skill — ms_token cookie from tiktok.com
# ms_token=your_ms_token_here
